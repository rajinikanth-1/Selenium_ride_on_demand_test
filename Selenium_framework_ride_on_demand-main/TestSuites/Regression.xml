<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Regression Suite" parallel="tests" thread-count="6">

    <listeners>
        <listener class-name="Utils.Listener"/>
    </listeners>

    <test name="Admin Regression Test">
        <groups>
            <run>
                <include name="admin_users"/>
            </run>
        </groups>

        <classes>
            <class name="org.example.admin_welcomepage"/>
        </classes>
    </test>

    <test name="Customer Regression Test">
        <groups>
            <run>
                <include name="customer_users"/>
            </run>
        </groups>

        <classes>
            <class name="org.example.customers_welcomepage"/>
        </classes>
    </test>

    <test name="Vendor Regression Test">
        <groups>
            <run>
                <include name="vendor_users"/>
            </run>
        </groups>

        <classes>
            <class name="org.example.vendor_welcomepage"/>
        </classes>
    </test>

</suite>